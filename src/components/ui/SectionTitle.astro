---
interface Props {
  title: string
  subtitle?: string
  align?: 'left' | 'center'
  as?: 'h2' | 'h3'
}

const { title, subtitle, align = 'left', as: Tag = 'h2' } = Astro.props

const containerClass = align === 'center' ? 'mb-10 text-center' : 'mb-10'
const titleClass = 'font-heading text-3xl md:text-4xl font-bold text-foreground leading-tight'
const subtitleClass = align === 'center'
  ? 'mt-3 text-base text-muted max-w-2xl mx-auto'
  : 'mt-3 text-base text-muted max-w-2xl'
---

<div class={containerClass}>
  <Tag class={titleClass}>{title}</Tag>
  {subtitle && <p class={subtitleClass}>{subtitle}</p>}
</div>
