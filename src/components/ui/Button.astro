---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost'
  size?: 'sm' | 'md' | 'lg'
  href?: string
  fullWidth?: boolean
  class?: string
  type?: 'button' | 'submit' | 'reset'
  [key: string]: unknown
}

const {
  variant = 'primary',
  size = 'md',
  href,
  fullWidth = false,
  class: className = '',
  type = 'button',
  ...rest
} = Astro.props

const base = 'inline-flex items-center justify-center gap-2 font-medium transition-all duration-200 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer'

const sizes = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3.5 text-base',
}

const variants = {
  primary: 'bg-accent text-white hover:bg-accent-hover active:scale-[0.98]',
  secondary: 'border border-accent text-accent hover:bg-accent hover:text-white',
  ghost: 'text-accent hover:bg-accent-subtle',
}

const classes = [
  base,
  sizes[size],
  variants[variant],
  fullWidth ? 'w-full' : '',
  className,
].filter(Boolean).join(' ')
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}
