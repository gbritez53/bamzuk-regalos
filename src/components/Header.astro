---
import { mainLinks, categoryGroups } from '../data/navigation'
import MobileDrawer from './MobileDrawer'
---

<header class="sticky top-0 z-30 bg-surface border-b border-border">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="font-heading text-xl font-bold text-accent hover:opacity-80 transition-opacity flex-shrink-0">
      Bamzuk
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Navegación principal">
      {mainLinks.map(link => (
        <a
          href={link.href}
          class="text-sm font-medium text-foreground hover:text-accent transition-colors"
        >
          {link.label}
        </a>
      ))}

      <!-- Mega menu trigger -->
      <div class="group relative">
        <button
          class="flex items-center gap-1 text-sm font-medium text-foreground hover:text-accent transition-colors py-2"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Categorías
          <svg
            width="14"
            height="14"
            viewBox="0 0 14 14"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            class="mt-0.5 transition-transform group-hover:rotate-180"
          >
            <path d="M3 5l4 4 4-4"/>
          </svg>
        </button>

        <!-- Mega panel: pure CSS reveal, zero JS -->
        <div class="absolute top-full right-0 invisible opacity-0 group-hover:visible group-hover:opacity-100 focus-within:visible focus-within:opacity-100 transition-all duration-200 pt-2 w-[720px]">
          <div class="bg-surface border border-border rounded-card shadow-card p-6">
            <div class="grid grid-cols-4 gap-6">
              {categoryGroups.map(group => (
                <div>
                  <h3 class="text-xs font-semibold text-muted uppercase tracking-wider mb-2">{group.title}</h3>
                  <ul class="space-y-1">
                    {group.items.map(item => (
                      <li>
                        <a
                          href={item.href}
                          class="text-xs text-foreground hover:text-accent transition-colors leading-relaxed block py-0.5"
                        >
                          {item.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Mobile hamburger (React island, md:hidden is inside MobileDrawer) -->
    <MobileDrawer client:load mainLinks={mainLinks} categoryGroups={categoryGroups} />

  </div>
</header>
