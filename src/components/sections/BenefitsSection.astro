---
import SectionTitle from '../ui/SectionTitle.astro'

const benefits = [
  {
    title: 'Ahorro de tiempo',
    description: 'Curada selección de los mejores regalos para que no pierdas horas buscando. Todo en un solo lugar.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    title: 'Variedad de categorías',
    description: 'Desde regalos para abuelas hasta para gamers. Más de 70 categorías para acertar siempre.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
  },
  {
    title: 'Recomendaciones honestas',
    description: 'Solo recomendamos lo que realmente vale la pena. Sin relleno, sin patrocinios ocultos.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  },
  {
    title: 'Inspiración práctica',
    description: 'Ideas concretas y accionables. Cada sugerencia viene con descripción y enlace directo.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>`,
  },
  {
    title: 'Enlace directo a Amazon',
    description: 'Compra con la confianza de Amazon. Entrega rápida, devoluciones fáciles y precios competitivos.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`,
  },
]
---

<section class="bg-background py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-6">
    <SectionTitle
      title="¿Por qué elegir Bamzuk?"
      subtitle="Todo lo que necesitás para regalar bien, sin complicaciones"
      align="center"
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {benefits.map(benefit => (
        <div class="bg-surface rounded-card shadow-card p-6 flex flex-col gap-3">
          <div class="w-11 h-11 rounded-lg bg-accent-subtle flex items-center justify-center text-accent flex-shrink-0">
            <Fragment set:html={benefit.icon} />
          </div>
          <h3 class="font-semibold text-foreground text-base">{benefit.title}</h3>
          <p class="text-sm text-muted leading-relaxed">{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
