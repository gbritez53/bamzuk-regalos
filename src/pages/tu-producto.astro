---
import Layout from '../layouts/Layout.astro'
import Button from '../components/ui/Button.astro'
import SectionTitle from '../components/ui/SectionTitle.astro'

const requirements = [
  'El producto debe estar disponible en Amazon España (amazon.es)',
  'Debe tener un mínimo de reseñas positivas y buena valoración',
  'Tiene que ser apto para regalar — original, práctico o especial',
]

const steps = [
  {
    number: '01',
    title: 'Escribinos',
    description: 'Contanos sobre tu producto: qué es, a quién va dirigido y por qué creés que encaja en Bamzuk.',
  },
  {
    number: '02',
    title: 'Lo evaluamos',
    description: 'Nuestro equipo revisa el producto, sus reseñas en Amazon y si encaja con alguna de nuestras categorías.',
  },
  {
    number: '03',
    title: 'Lo publicamos',
    description: 'Si cumple los criterios, lo incluimos en la categoría correspondiente con un enlace de afiliado a Amazon.',
  },
]
---

<Layout title="Tu Producto — Bamzuk">

  <!-- Banner -->
  <section class="bg-background py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-foreground leading-tight">
        ¿Vendés en Amazon?
      </h1>
      <p class="mt-4 text-lg text-muted max-w-2xl mx-auto leading-relaxed">
        Si tenés un producto en Amazon que creés que merece estar en Bamzuk, nos encantaría conocerlo.
      </p>
    </div>
  </section>

  <!-- Requirements -->
  <section class="bg-surface py-16">
    <div class="max-w-4xl mx-auto px-6">
      <SectionTitle
        title="¿Qué buscamos?"
        subtitle="Para que tu producto pueda aparecer en Bamzuk, debe cumplir estos criterios"
      />
      <ul class="space-y-4">
        {requirements.map(req => (
          <li class="flex items-start gap-3">
            <span class="mt-0.5 flex-shrink-0 w-6 h-6 rounded-full bg-accent-subtle flex items-center justify-center">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-accent">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            <p class="text-base text-muted leading-relaxed">{req}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-background py-16">
    <div class="max-w-4xl mx-auto px-6">
      <SectionTitle
        title="¿Cómo funciona?"
        subtitle="El proceso es simple y sin compromiso"
        align="center"
      />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8">
        {steps.map(step => (
          <div class="flex flex-col gap-3">
            <span class="font-heading text-4xl font-bold text-accent/20">{step.number}</span>
            <h3 class="font-semibold text-foreground text-base">{step.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-accent py-16">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-white">¿Tu producto encaja?</h2>
      <p class="mt-3 text-white/80 text-base">Escribinos y lo vemos juntos. El proceso es gratuito y sin compromiso.</p>
      <div class="mt-8">
        <Button href="/contactanos" variant="secondary" size="lg" class="border-white text-white hover:bg-white hover:text-accent">
          Escribinos ahora
        </Button>
      </div>
    </div>
  </section>

</Layout>
