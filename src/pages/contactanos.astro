---
import Layout from '../layouts/Layout.astro'
import Button from '../components/ui/Button.astro'
import SectionTitle from '../components/ui/SectionTitle.astro'

const subjectOptions = [
  'Sugerencia de regalo',
  'Propuesta de colaboración',
  'Consulta general',
  'Problema técnico',
]

const inputClass = 'w-full border border-border rounded-lg px-4 py-3 text-foreground bg-surface focus:outline-none focus:ring-2 focus:ring-accent transition-shadow text-sm'
---

<Layout title="Contáctanos — Bamzuk">

  <!-- Banner -->
  <section class="bg-background py-20">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h1 class="font-heading text-4xl md:text-5xl font-bold text-foreground leading-tight">
        Contáctanos
      </h1>
      <p class="mt-4 text-lg text-muted max-w-xl mx-auto leading-relaxed">
        ¿Tenés una sugerencia, una pregunta o querés que tu producto aparezca en Bamzuk? Escribinos.
      </p>
    </div>
  </section>

  <!-- Form -->
  <section class="bg-surface py-16">
    <div class="max-w-2xl mx-auto px-6">
      <SectionTitle title="Envianos un mensaje" />

      <form
        action="https://formspree.io/f/REPLACE_WITH_ID"
        method="POST"
        class="space-y-5"
      >
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="flex flex-col gap-1.5">
            <label for="name" class="text-sm font-medium text-foreground">Nombre <span class="text-accent">*</span></label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="Tu nombre"
              class={inputClass}
            />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="email" class="text-sm font-medium text-foreground">Email <span class="text-accent">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="tu@email.com"
              class={inputClass}
            />
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="subject" class="text-sm font-medium text-foreground">Asunto</label>
          <select id="subject" name="subject" class={inputClass}>
            {subjectOptions.map(opt => <option value={opt}>{opt}</option>)}
          </select>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="message" class="text-sm font-medium text-foreground">Mensaje <span class="text-accent">*</span></label>
          <textarea
            id="message"
            name="message"
            required
            rows={5}
            placeholder="Contanos en qué podemos ayudarte..."
            class={inputClass}
          />
        </div>

        <Button type="submit" variant="primary" size="lg" fullWidth>
          Enviar mensaje
        </Button>
      </form>

      <p class="mt-6 text-center text-sm text-muted">
        También podés escribirnos directamente a
        <a href="mailto:hola@bamzuk.com" class="text-accent hover:underline ml-1">hola@bamzuk.com</a>
      </p>
    </div>
  </section>

</Layout>
